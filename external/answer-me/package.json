{
  "name": "@root/answer-me",
  "version": "1.0.1",
  "private": true,
  "workspaces": [
    "external/*",
    "external/*/external/*",
    "external/*/packages/*",
    "packages/*"
  ],
  "license": "MIT",
  "scripts": {
    "build": "npm run --prefix ../.. build -- answer-me",
    "start": "npm run --prefix ../.. start -- answer-me",
    "dev": "npm run --prefix ../.. dev -- answer-me",
    "bump": "yakumo version",
    "dep": "yakumo upgrade",
    "pub": "yakumo publish"
  },
  "devDependencies": {
    "@koishijs/client": "^5.30.4",
    "@koishijs/plugin-hmr": "^1.2.9",
    "@koishijs/scripts": "^4.6.1",
    "@types/node": "^22.7.5",
    "@types/react": "^18.2.70",
    "cross-env": "^7.0.3",
    "esbuild": "^0.23.1",
    "esbuild-register": "npm:@shigma/esbuild-register@^1.1.1",
    "tsx": "^4.16.2",
    "typescript": "^5.6.2",
    "yakumo": "^1.0.0-beta.21",
    "yakumo-esbuild": "^1.0.0-beta.7",
    "yakumo-tsc": "^1.0.0-beta.5",
    "yml-register": "^1.2.5"
  }
}
